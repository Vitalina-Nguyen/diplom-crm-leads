generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    String @id @default(uuid()) @db.Uuid
  name  String @unique
  users User[]
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  fullName  String
  email     String   @unique
  roleId    String   @db.Uuid
  role      Role     @relation(fields: [roleId], references: [id])
  active    Boolean  @default(true)
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadsCreated Lead[] @relation("LeadCreatedBy")

  leadAssignees LeadAssignee[]

  statusChanges LeadStatusHistory[]

  assignmentHistories LeadAssignmentHistory[]

  priorityChanges LeadPriorityHistory[]
}

enum LeadStatus {
  NEW
  INITIAL_ESTIMATION_NEEDS_CLARIFICATION
  ASSIGNED_TO_EXECUTOR
  IN_DISCUSSION
  COMPLETED
  REJECTED
  POSTPONED
}

/** Порядок значений задаёт сортировку по возрастанию: низкий → средний → высокий. */
enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

model LeadSource {
  id           String            @id @default(uuid()) @db.Uuid
  name         String            @unique
  leads        Lead[]
  ingestTokens LeadIngestToken[]
}

/** Токен для приёма лидов из внешних систем (только Admin). Полный секрет не хранится — только SHA-256 и маска «xx…yy». */
model LeadIngestToken {
  id           String     @id @default(uuid()) @db.Uuid
  displayName  String
  sourceId     String     @db.Uuid
  source       LeadSource @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  tokenHash    String     @unique
  /** Маска для списка: первые 2 + «...» + последние 2 символа исходного токена. */
  tokenPreview String
  createdAt    DateTime   @default(now())
}

model Lead {
  id          String       @id @db.Uuid
  companyName String
  contactName String
  description String?
  sourceId    String       @db.Uuid
  source      LeadSource   @relation(fields: [sourceId], references: [id])
  status      LeadStatus
  priority    LeadPriority @default(MEDIUM)
  budget      Decimal?     @db.Decimal(14, 2)
  finishDate  DateTime?    @db.Date
  createdById String       @db.Uuid
  createdBy   User         @relation("LeadCreatedBy", fields: [createdById], references: [id])
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  contacts          LeadContact[]
  assignees         LeadAssignee[]
  statusHistory     LeadStatusHistory[]
  assignmentHistory LeadAssignmentHistory[]
  priorityHistory   LeadPriorityHistory[]
}

model LeadContact {
  id          String   @id @default(uuid()) @db.Uuid
  leadId      String   @db.Uuid
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sourceType  String
  sourceValue String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeadAssignee {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @db.Uuid
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([leadId, userId])
}

model LeadStatusHistory {
  id             String       @id @default(uuid()) @db.Uuid
  leadId         String       @db.Uuid
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  previousStatus LeadStatus?
  newStatus      LeadStatus
  changedById    String       @db.Uuid
  changedBy      User         @relation(fields: [changedById], references: [id])
  changedAt      DateTime     @default(now())
  comment        String?
}

model LeadPriorityHistory {
  id               String        @id @default(uuid()) @db.Uuid
  leadId           String        @db.Uuid
  lead             Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  previousPriority LeadPriority?
  newPriority      LeadPriority
  changedById      String        @db.Uuid
  changedBy        User          @relation(fields: [changedById], references: [id])
  changedAt        DateTime      @default(now())
  comment          String?
}

enum AssignmentAction {
  ADDED
  REMOVED
}

model LeadAssignmentHistory {
  id        String           @id @default(uuid()) @db.Uuid
  leadId    String           @db.Uuid
  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id])
  action    AssignmentAction
  createdAt DateTime         @default(now())
  comment   String?
}
