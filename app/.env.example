# Скопируйте в `.env` или `.env.local`. Должно совпадать с корневым `.env` (POSTGRES_*).
# Если строка неверная — seed и приложение дадут P1000 (authentication failed).
DATABASE_URL="postgresql://app:app@localhost:5432/app"

# Опционально: закомментируйте DATABASE_URL выше — тогда `prisma/seed.ts` соберёт URL из
# корневого `.env`: POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, POSTGRES_PORT
# (хост для хоста: localhost; значение postgres из compose подменяется на localhost).

# Секрет для подписи JWT сессии (минимум 32 символа в продакшене)
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
